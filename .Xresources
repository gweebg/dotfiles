! X colors.
! Generated by 'wal'
*foreground:        #c3dde4
*background:        #111018
*.foreground:       #c3dde4
*.background:       #111018
emacs*foreground:   #c3dde4
emacs*background:   #111018
URxvt*foreground:   #c3dde4
XTerm*foreground:   #c3dde4
UXTerm*foreground:  #c3dde4
URxvt*background:   [100]#111018
XTerm*background:   #111018
UXTerm*background:  #111018
URxvt*cursorColor:  #c3dde4
XTerm*cursorColor:  #c3dde4
UXTerm*cursorColor: #c3dde4
URxvt*borderColor:  [100]#111018

! Colors 0-15.
*.color0: #111018
*color0:  #111018
*.color1: #AD7498
*color1:  #AD7498
*.color2: #6E93CC
*color2:  #6E93CC
*.color3: #73B2C4
*color3:  #73B2C4
*.color4: #7DB8CF
*color4:  #7DB8CF
*.color5: #8E93BA
*color5:  #8E93BA
*.color6: #85A7C7
*color6:  #85A7C7
*.color7: #c3dde4
*color7:  #c3dde4
*.color8: #889a9f
*color8:  #889a9f
*.color9: #AD7498
*color9:  #AD7498
*.color10: #6E93CC
*color10:  #6E93CC
*.color11: #73B2C4
*color11:  #73B2C4
*.color12: #7DB8CF
*color12:  #7DB8CF
*.color13: #8E93BA
*color13:  #8E93BA
*.color14: #85A7C7
*color14:  #85A7C7
*.color15: #c3dde4
*color15:  #c3dde4

! Black color that will not be affected by bold highlighting.
*.color66: #111018
*color66:  #111018

! Xclock colors.
XClock*foreground: #c3dde4
XClock*background: #111018
XClock*majorColor:  rgba:c3/dd/e4/ff
XClock*minorColor:  rgba:c3/dd/e4/ff
XClock*hourColor:   rgba:c3/dd/e4/ff
XClock*minuteColor: rgba:c3/dd/e4/ff
XClock*secondColor: rgba:c3/dd/e4/ff

! Set depth to make transparency work.
URxvt*depth: 32
