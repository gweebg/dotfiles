[user]
	email = guilherme.g.sampaio@gmail.com
	name = Guilherme Sampaio
	signingkey = /home/guilherme/.ssh/id_signingkey.pub

[init]
  defaultBranch = main

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[gpg]
    format = ssh

[commit]
    gpgsign = true
